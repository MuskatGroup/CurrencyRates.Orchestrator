# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=currencyrates

# JWT (shared: User / Finance / Gateway)
JWT_ISSUER=CurrencyRates
JWT_AUDIENCE=CurrencyRates
# В production: openssl rand -base64 48 (минимум 32 символа)
JWT_SECRET_KEY=CurrencyRates_Dev_SecretKey_ChangeMe_32+

# Finance Service
FINANCE_ASPNETCORE_URLS=http://+:8080
FINANCE_ASPNETCORE_ENVIRONMENT=Development
FINANCE_HOST_PORT=5002
FINANCE_CONNECTION_STRING=Host=postgres;Port=5432;Database=currencyrates;Username=postgres;Password=postgres
FINANCE_SEED_ENABLED=true
FINANCE_SEED_TEST_USER_ID=11111111-1111-1111-1111-111111111111
FINANCE_SEED_TEST_USER_NAME=demo

# Gateway Service
GATEWAY_ASPNETCORE_URLS=http://+:8080
GATEWAY_ASPNETCORE_ENVIRONMENT=Development
GATEWAY_HOST_PORT=5000
GATEWAY_FINANCE_ADDRESS=http://finance:8080/
GATEWAY_USERS_ADDRESS=http://user:8080/
